# ============================================
# NailMasters — Переменные окружения
# ============================================

# База данных PostgreSQL
DATABASE_URL=postgres://nailmasters:nailmasters_secret@localhost:5432/nailmasters

# Redis
REDIS_URL=redis://localhost:6379

# NextAuth
AUTH_SECRET=change-me-to-a-random-64-char-string
AUTH_URL=http://localhost:3000

# JWT (для внутреннего использования)
JWT_SECRET=change-me-jwt-secret-key
JWT_REFRESH_SECRET=change-me-refresh-secret-key
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Админский секретный ключ для регистрации
ADMIN_REGISTRATION_SECRET=admin_secret_key_2026

# Приложение
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# Логирование
LOG_LEVEL=debug
ENABLE_REQUEST_LOGGING=false
ENABLE_RESPONSE_LOGGING=false

# Загрузка файлов
MAX_IMAGE_SIZE_MB=10
MAX_VIDEO_SIZE_MB=100
MAX_AVATAR_SIZE_MB=5
UPLOAD_DIR=public/uploads
